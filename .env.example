# ══════════════════════════════════════════════
#  ملف الإعدادات البيئية — انسخه إلى .env
#  لا ترفع هذا الملف إلى GitHub أبداً!
# ══════════════════════════════════════════════

# ── قاعدة البيانات ──
# للتطوير (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./sentiment_ai.db
# للإنتاج (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/sentimentai

# ── النموذج ──
# "logistic" أو "arabert"
MODEL_TYPE=logistic
ARABERT_MODEL_NAME=aubmindlab/bert-base-arabertv2

# ── Facebook Graph API ──
FACEBOOK_APP_ID=your_app_id_here
FACEBOOK_APP_SECRET=your_app_secret_here
FACEBOOK_ACCESS_TOKEN=your_page_access_token_here

# ── الأمان ──
SECRET_KEY=replace-with-random-64-char-string

# ── CORS ──
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
